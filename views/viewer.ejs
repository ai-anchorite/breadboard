<!DOCTYPE html>
<html class="<%=theme%>">
  <head>
    <meta charset="UTF-8">
    <title>Image Viewer</title>
    <link href="./viewer.css" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 100%; height: 100%; overflow: hidden; }
      body { background: #000; display: flex; align-items: center; justify-content: center; }
      body.default { background: #fff; }
      #viewer-container { display: none; }
    </style>
  </head>
  <body>
    <div id="viewer-container"></div>
    <script src="./socket.io.js"></script>
    <script src="./viewer.js"></script>
    <script src="./modules/api.js"></script>
    <script>
      let viewer;

      ;(async () => {
        const api = new API({ agent: "<%=agent%>" })

        // Get slideshow interval setting
        let slideshowRes = await api.getSetting('slideshow_interval')
        const slideshowInterval = slideshowRes.val ? parseInt(slideshowRes.val) : 3000

        // Get the current file path and optional query from URL
        const urlParams = new URLSearchParams(window.location.search)
        const currentFile = urlParams.get('file')
        const query = urlParams.get('query') || ''

        // Get images via API (same query as the gallery view, or all if no query)
        const result = await api.searchImages(query, { sort: 'btime', direction: -1, limit: 5000, offset: 0 })
        const images = result.results || []

        if (images.length === 0) {
          document.body.innerHTML = '<div style="color: white; text-align: center; padding: 20px;">No images found</div>'
          return
        }

        // Find the index of the current image
        const currentIndex = images.findIndex(img => img.file_path === currentFile)

        // Create image elements for the viewer
        const container = document.getElementById('viewer-container')
        images.forEach(img => {
          const imgEl = document.createElement('img')
          imgEl.src = `/file?file=${encodeURIComponent(img.file_path)}`
          imgEl.alt = img.prompt || ''
          container.appendChild(imgEl)
        })

        // Initialize Viewer.js
        viewer = new Viewer(container, {
          inline: false,
          initialViewIndex: currentIndex >= 0 ? currentIndex : 0,
          transition: false,
          interval: slideshowInterval,
          toolbar: {
            'zoomIn': true, 'zoomOut': true, 'reset': true,
            'prev': true, 'play': true, 'next': true,
            'oneToOne': true, 'rotateLeft': true, 'rotateRight': true,
            'flipHorizontal': true, 'flipVertical': true
          },
          viewed(e) {
            const img = viewer.image
            if (img && img.naturalWidth && img.naturalHeight) {
              const availableHeight = window.innerHeight - 100
              const scaleFactor = Math.min(
                window.innerWidth / img.naturalWidth,
                availableHeight / img.naturalHeight
              )
              viewer.zoomTo(scaleFactor)
            }
          },
          hidden() { window.close() },
          title: false,
          navbar: true,
          keyboard: true,
          backdrop: true
        })

        viewer.show()
      })()
    </script>
  </body>
</html>
