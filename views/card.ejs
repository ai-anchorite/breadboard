<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>breadboard</title>
    <link href="/css/fontawesome.min.css" rel="stylesheet">
    <link href="/css/solid.min.css" rel="stylesheet">
    <link href="/css/regular.min.css" rel="stylesheet">
    <link href="/css/brands.min.css" rel="stylesheet">
    <link href="./global.css" rel="stylesheet" />
    <% if (agent === "electron") { %>
    <link href="./electron.css" rel="stylesheet" />
    <% } %>
  </head>
  <body class="<%=theme%>" data-style="<%=style%>">
    <nav>
      <div class='nav-unit left-menu'>
        <a title="home" class='btn' href="/"><i class="fa-solid fa-house"></i></a>
      </div>
      <div class='status'></div>
    </nav>
    <div class='pop container' data-src="<%=file_path%>"></div>
    <script src="./modules/api.js"></script>
    <script src="./modules/card.js"></script>
    <script src="./modules/handler.js"></script>
    <script src="./socket.io.js"></script>
    <script src='./hotkeys.js'></script>
    <script src="./timeago.js"></script>
    <script src='./popper.js'></script>
    <script src="./tippy.js"></script>
    <script src="./viewer.js"></script>
    <script>
      const VERSION = "<%=version%>"
      const AGENT = "<%=agent%>"
      const api = new API({ agent: AGENT })

      hotkeys("*", (e, handler) => {})

      const app = {
        stripPunctuation: (str) => {
          return str
            .replaceAll("&quot;", " ")
            .replace(/[.,\/#!$%\^&\*;:\[\]{}=\-_`"~()\\\|+]/g, " ")
            .replace(/\s{2,}/g, " ");
        },
        synchronize: async (paths, cb) => {
          document.querySelector(".status").innerHTML = "synchronizing..."
          app.sync_counter = 0
          app.sync_complete = false
          await new Promise((resolve, reject) => {
            api.sync({ paths })
            let interval = setInterval(() => {
              if (app.sync_complete) {
                clearInterval(interval)
                resolve()
              }
            }, 1000)
          })
          if (cb) await cb()
        },
        navbar: {
          input: (key, val) => {
            let existingPromptTokens = []
            let existingAdvancedTokens = []

            if (key === "prompt" || key === "-prompt") {
              let istag = /^-?tag:/.test(val)
              let cleaned = (istag ? val : app.stripPunctuation(val))
              if (key === "-prompt") {
                existingPromptTokens.push(istag ? cleaned : "-:" + cleaned)
              } else {
                existingPromptTokens.push(cleaned)
              }
            } else {
              existingAdvancedTokens.push(key + ":" + val)
            }

            let result = [...existingPromptTokens, ...existingAdvancedTokens]
            let query = result.join(" ")

            if (query && query.length > 0) {
              let params = new URLSearchParams({ query })
              let newWin = hotkeys.isPressed("ctrl") || hotkeys.isPressed("cmd")
              if (newWin) {
                window.open("/?" + params.toString(), "_blank", "popup")
              } else {
                location.href = "/?" + params.toString()
              }
            }
          }
        }
      }

      const handler = new Handler(app, api);

      ;(async () => {
        // Init theme
        let themeRes = await api.getSetting('theme')
        let theme = themeRes.val || "default"
        document.body.className = theme
        document.querySelector("html").className = theme

        // Load image by file_path via search API
        let filePath = document.querySelector(".container").getAttribute("data-src")
        let result = await api.searchImages(`file_path:"${filePath}"`, { limit: 1 })

        if (result.results && result.results.length > 0) {
          let item = result.results[0]
          // Build tokens for card.js compatibility
          let tokens = []
          if (item.prompt && typeof item.prompt === 'string') {
            tokens = app.stripPunctuation(item.prompt).split(/\s/).filter(t => t.length > 0)
          }
          if (item.tags && item.tags.length > 0) {
            for (let tag of item.tags) tokens.push("tag:" + tag)
          }
          item.tokens = tokens

          let html = `<div class='card expanded popup-card' data-root="${item.root_path}" data-src="${item.file_path}" data-fingerprint="${item.fingerprint}">${card(item, app.stripPunctuation)}</div>`
          document.querySelector(".container").innerHTML = html
        } else {
          document.querySelector(".container").innerHTML = "<div class='center-faded'>Image not found in database. Try re-indexing.</div>"
        }

        // Listen for sync progress
        api.listen(async (_event, value) => {
          if (!value.method) {
            app.sync_counter++
            if (app.sync_counter === value.total) app.sync_complete = true
          }
        })
      })()
    </script>
  </body>
</html>
